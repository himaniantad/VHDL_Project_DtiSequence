library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity tb_rans_decoder_top is
end;

architecture sim of tb_rans_decoder_top is

    signal clk : std_logic := '0';
    signal rst : std_logic := '1';

    signal byte_in    : std_logic_vector(7 downto 0);
    signal byte_valid : std_logic := '0';
    signal byte_ready : std_logic;

    signal symbol_out : unsigned(3 downto 0);
    signal sym_valid  : std_logic;

begin

    clk <= not clk after 5 ns;

    uut: entity work.rans_decoder_top
        port map(
            clk => clk,
            rst => rst,
            byte_in => byte_in,
            byte_valid => byte_valid,
            byte_ready => byte_ready,
            symbol_out => symbol_out,
            sym_valid => sym_valid
        );

    process
    begin
        wait for 20 ns;
        rst <= '0';

        for i in 0 to 10 loop
            wait until rising_edge(clk);
            byte_in <= std_logic_vector(to_unsigned(i*7 + 15, 8));
            byte_valid <= '1';

            wait until rising_edge(clk);
            byte_valid <= '0';
        end loop;

        wait for 500 ns;
        wait;
    end process;

end architecture;