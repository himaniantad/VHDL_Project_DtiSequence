library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use work.rans_pkg.all;

entity rans_decoder is
    port (
        clk        : in  std_logic;
        rst        : in  std_logic;
        bit_in     : in  std_logic;
        bit_valid  : in  std_logic;
        symbol_out : out unsigned(3 downto 0);
        sym_valid  : out std_logic
    );
end entity;

architecture rtl of rans_decoder is
    signal x : unsigned(STATE_W-1 downto 0);
begin

    process(clk, rst)
        variable r      : integer;
        variable s      : integer;
        variable x_next : unsigned(STATE_W-1 downto 0);
    begin
        if rst = '1' then
            x <= to_unsigned(2*L, STATE_W);
            symbol_out <= (others => '0');
            sym_valid  <= '0';

        elsif rising_edge(clk) then

            sym_valid <= '0';

            ----------------------------------
            -- RENORMALIZATION
            ----------------------------------
            if x < to_unsigned(L, STATE_W) then
                if bit_valid = '1' then
                    x <= x(STATE_W-2 downto 0) & bit_in;
                end if;

            ----------------------------------
            -- DECODING
            ----------------------------------
            else
                -- FIX 1: Use fully qualified M
                r := to_integer(x mod work.rans_pkg.M);

                -- FIX 2: Safe inverse CDF
                s := 0;
                for i in 0 to 15 loop
                    if r >= integer(work.rans_pkg.Bs(i)) then
                        s := i;
                    end if;
                end loop;

                -- FIX 3: Safe arithmetic
                x_next :=
                    resize(to_unsigned(work.rans_pkg.Fs(s), STATE_W) *
                    (x / work.rans_pkg.M) +
                    to_unsigned(r - work.rans_pkg.Bs(s), STATE_W) ,STATE_W );

                x <= x_next;

                symbol_out <= to_unsigned(s, 4);
                sym_valid  <= '1';
            end if;

        end if;
    end process;

end architecture;